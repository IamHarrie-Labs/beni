    "agent_wallet/WalletDatum": {
      "title": "WalletDatum",
      "description": "Datum holds all guardrail rules and rolling window state for the agent wallet.\n Field order is load-bearing — the TypeScript SDK encodes this via Lucid's\n Data.Object and must match this declaration order exactly.",
      "anyOf": [
        {
          "title": "WalletDatum",
          "dataType": "constructor",
          "index": 0,
          "fields": [
            {
              "title": "per_tx_cap",
              "description": "Max lovelace the agent can spend in a single tx (to non-whitelisted addresses)",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "daily_cap",
              "description": "Max lovelace the agent can spend in any 24h rolling window",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "allowed_addresses",
              "description": "Payment credential hashes the agent is allowed to send to freely",
              "$ref": "#/definitions/List$ByteArray"
            },
            {
              "title": "owner_pkh",
              "description": "Owner's payment credential hash — required to co-sign OwnerAction and FreezeWallet",
              "$ref": "#/definitions/ByteArray"
            },
            {
              "title": "last_window_start",
              "description": "POSIX milliseconds when the current 24h window started",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "window_spent",
              "description": "Lovelace spent so far in the current window",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "is_frozen",
              "description": "Emergency freeze flag — when True, all Spend redeemers are rejected",
              "$ref": "#/definitions/Bool"
            },
            {
              "title": "thread_token_policy",
              "description": "Policy ID of the thread token NFT minted at wallet creation",
              "$ref": "#/definitions/ByteArray"
            }
          ]
        }
      ]
    },
    "agent_wallet/WalletRedeemer": {
      "title": "WalletRedeemer",
      "description": "Redeemer signals what action is being performed.",
      "anyOf": [
        {
          "title": "Spend",
          "description": "Normal agent spend — subject to all guardrail rules",
          "dataType": "constructor",
          "index": 0,
          "fields": []
        },
        {
          "title": "OwnerAction",
          "description": "Owner reclaims funds or updates the wallet config",
          "dataType": "constructor",
          "index": 1,
          "fields": []
        },
        {
          "title": "FreezeWallet",
          "description": "Owner emergency-freezes the wallet (blocks all future Spend)",
          "dataType": "constructor",
          "index": 2,
          "fields": []
        }
      ]
    },
