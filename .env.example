# Beni environment variables
# Copy this file to .env and fill in your values

# Claude API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Blockfrost API key for Preview testnet (get one at https://blockfrost.io)
BLOCKFROST_PREVIEW_KEY=previewXXXXXXXXXXXXXXXX

# Agent private key (hex-encoded ed25519 private key for Preview testnet)
AGENT_PRIVATE_KEY=
