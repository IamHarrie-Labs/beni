# ── Telegram ──────────────────────────────────────────────────────────────
# Create a bot with @BotFather on Telegram and paste the token it gives you.
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# Optional: the chat that should receive above-cap approval prompts.
# Leave blank to send approvals back to whoever made the request.
# Get your id by messaging @userinfobot.
BENI_OWNER_CHAT_ID=

# ── Cardano (Preview testnet) ─────────────────────────────────────────────
# Same values your dashboard / Vercel deployment uses.
BLOCKFROST_PREVIEW_KEY=previewXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AGENT_PRIVATE_KEY=ed25519_sk1...

# Optional: path to the deployment record. Defaults to ../../beni-wallet-state.json
# (the repo root file written by the deploy script / dashboard).
# BENI_STATE_PATH=/absolute/path/to/beni-wallet-state.json

# Optional: share the approval queue with the web dashboard by pointing at the
# deployed /api/approvals endpoint. If unset, the bot uses a local JSON file.
# BENI_APPROVALS_API=https://beni-wallet.vercel.app/api/approvals
