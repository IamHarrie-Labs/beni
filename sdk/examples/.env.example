# Beni SDK — Environment Variables
# Copy to .env and fill in real values before running examples.

# Blockfrost API key for Cardano Preview testnet
# Get one free at: https://blockfrost.io
BLOCKFROST_PREVIEW_KEY=previewXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Agent wallet private key (ed25519 — the wallet the AI agent controls)
# Generate with: npx tsx -e "import {generatePrivateKey} from 'lucid-cardano'; console.log(generatePrivateKey())"
AGENT_PRIVATE_KEY=ed25519_sk1...

# Owner private key (human who controls the agent wallet guardrails)
OWNER_PRIVATE_KEY=ed25519_sk1...

# Anthropic API key (for the AI chatbot)
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
