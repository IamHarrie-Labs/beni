{
  "name": "beni-sdk",
  "version": "0.1.0",
  "description": "AI agent wallet guardrails on Cardano",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "npx tsx --test src/test/validation.test.ts",
    "typecheck": "tsc --noEmit",
    "chat": "npx tsx src/chat-server.ts",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/IamHarrie-Labs/beni.git",
    "directory": "sdk"
  },
  "homepage": "https://github.com/IamHarrie-Labs/beni#readme",
  "keywords": [
    "cardano",
    "aiken",
    "ai-agent",
    "wallet",
    "guardrails"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.37.0",
    "@blockfrost/blockfrost-js": "^5.4.0",
    "@lucid-evolution/lucid": "^0.4.31",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "lucid-cardano": "^0.10.7"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
